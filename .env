# =========================
# 前端：赛事信息
# =========================

# 页头和浏览器标签页显示的赛事名称
VITE_EVENT_TITLE=华北水利水电大学第八届 ACM-ICPC 程序设计大赛

# 比赛开始时间
# 当前时间早于这个时间时，整页会显示“距离比赛开始”倒计时
# 时间格式示例：2026-03-25T20:00:00+08:00
VITE_EVENT_START_AT=2026-03-26T14:30:00+08:00

# 开赛前倒计时的大标题和副标题
VITE_EVENT_START_COUNTDOWN_TITLE=距离比赛开始
VITE_EVENT_START_COUNTDOWN_SUBTITLE=大屏将在配置时间到达后自动开启

# =========================
# 前端：接口与实时连接
# =========================

# 接口基础前缀
VITE_API_BASE_PATH=/api

# 榜单接口
VITE_RANK_LIST_PATH=/api/get_rank_list

# 首刀初始化接口
VITE_FIRST_BLOOD_PATH=/api/get_first_blood

# 浏览器连接的 WebSocket 地址
VITE_KAFKA_WS_URL=/ws

# =========================
# 前端：赛中倒计时
# =========================

# 超过这个时间后，左侧和中间区域切换为 1 小时倒计时
# 留空表示不启用
# 时间格式示例：2026-03-25T21:00:00+08:00
VITE_COUNTDOWN_TRIGGER_AT=2026-03-26T17:30:00+08:00

# 倒计时持续分钟数
VITE_COUNTDOWN_DURATION_MINUTES=60

# 赛中倒计时的大标题和副标题
VITE_COUNTDOWN_TITLE=倒计时
VITE_COUNTDOWN_SUBTITLE=首刀与判题流已切换为倒计时模式

# =========================
# 前端：榜单
# =========================

# 榜单每页展示条数
VITE_RANK_PAGE_SIZE=10

# 榜单翻页间隔，单位毫秒
VITE_RANK_ROTATE_MS=5000

# 榜单是否自动开始同步
VITE_RANK_AUTO_START=true

# =========================
# 本地开发：Vite 开发服务器
# =========================

DEV_SERVER_HOST=0.0.0.0
DEV_SERVER_PORT=5173

# 允许访问的主机名，多个用英文逗号分隔；留空使用 Vite 默认行为
DEV_ALLOWED_HOSTS=39.106.71.161

# 本地开发时的接口和 WebSocket 代理目标
DEV_API_PROXY_TARGET=http://47.104.231.163:8090
DEV_WS_PROXY_TARGET=ws://39.106.71.161:8080

# =========================
# 部署：Nginx / 服务器
# =========================

SERVER_NAME=39.106.71.161
STATIC_ROOT=/opt/acm-board/frontend/dist
API_PROXY_TARGET=http://47.104.231.163:8090
WS_PROXY_TARGET=http://127.0.0.1:8080
FRONTEND_PORT=80

# =========================
# Kafka WebSocket 代理
# =========================

KAFKA_BROKERS=49.234.197.24:9092
KAFKA_TOPIC=acm.board.submission.events
KAFKA_CLIENT_ID=acm-board-proxy
KAFKA_GROUP_ID=acm-board-ws-proxy
KAFKA_FROM_BEGINNING=false

# 如果 Kafka 开启了 SSL/TLS，这里改为 true
KAFKA_SSL=false

# 可选：Kafka SASL 认证配置
KAFKA_SASL_MECHANISM=
KAFKA_USERNAME=
KAFKA_PASSWORD=

# 本地 WebSocket 代理监听地址
WS_HOST=0.0.0.0
WS_PORT=8080
